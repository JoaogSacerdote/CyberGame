# Defaults do projeto CyberGame.
# Sao aplicados quando sdkconfig nao existe (build limpo) ou quando algum
# valor aqui ainda nao esta presente no sdkconfig gerado.
#
# Para forcar reaplicacao apos editar:
#   idf.py fullclean && idf.py build
# Ou alternativamente:
#   idf.py menuconfig  (e salvar)

# --- TinyUSB ---
# Habilita classe CDC (Communication Device Class) — necessaria pelo
# components/recovery/. Sem isso, tusb_cdc_acm.h aborta o build com
# "TinyUSB CDC driver must be enabled in menuconfig".
CONFIG_TINYUSB_CDC_ENABLED=y

# --- PSRAM Octal 80MHz ---
# ESP32-S3 N16R8: 8MB Octal PSRAM. Necessario para o framebuffer do display
# (480x320 RGB565 = ~307KB) — nao cabe na DRAM interna sozinha.
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y

# --- Flash 16MB (ESP32-S3 N16R8) ---
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# --- LVGL 9.3 ---
# RGB565 para casar com display_hal (DISPLAY_HAL_BYTES_PER_PIXEL = 2).
CONFIG_LV_COLOR_DEPTH_16=y
# LVGL com locking via FreeRTOS mutex (lv_lock/lv_unlock thread-safe).
CONFIG_LV_USE_OS_FREERTOS=y
# Sem padding entre linhas no buffer parcial: display_hal_draw_bitmap
# assume pixels densamente empacotados. Stride > width corrompe shapes
# (cada letra "deslocada" vira glifos alienigenas).
CONFIG_LV_DRAW_BUF_STRIDE_ALIGN=1
